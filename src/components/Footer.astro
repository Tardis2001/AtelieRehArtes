---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
import Clock from "../assets/clock.svg"
import Pin from "../assets/pin.svg"
const socialLinks = {
  instagram: "https://instagram.com/seu_perfil",
  facebook: "https://facebook.com/seu_perfil",
  whatsapp: "https://wa.me/seunumerodelefone?text=Oi!+Vim+pelo+site+e+gostaria+de+tirar+uma+duvida."
};
---

<footer class="bg-blue-950 text-blue-50 pt-16 pb-8 border-t border-blue-900/40 relative overflow-hidden">
  <div class="absolute bottom-0 left-0 w-50 h-50 bg-orange-900/20 blur-[60px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 pb-12 border-b border-blue-900">
      
      <div class="md:col-span-4 text-center md:text-left">
        <h3 class="text-xl font-serif font-bold text-white tracking-wide">
          Pontinhos de Amor
        </h3>
        <p class="mt-4 text-sm text-blue-200/70 leading-relaxed font-sans max-w-sm mx-auto md:mx-0">
          Trazendo mais aconchego para a sua rotina através de fios, nós e muito afeto. Cada peça conta uma história única.
        </p>
        
        <div class="mt-6 flex justify-center md:justify-start gap-4">

          <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-full bg-blue-900/50 hover:bg-blue-900 text-blue-100 hover:text-white border border-blue-900 transition-all duration-200" title="Siga no Instagram">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zM17.5 6.5h.01"/>
            </svg>
          </a>

          <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-full bg-blue-900/50 hover:bg-blue-900 text-blue-100 hover:text-white border border-blue-900 transition-all duration-200" title="Acompanhe no Facebook">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

          <a href={socialLinks.whatsapp} target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-full bg-blue-900/50 hover:bg-blue-800 text-blue-100 hover:text-emerald-400 border border-blue-900 transition-all duration-200" title="Fale pelo WhatsApp">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a.598.598 0 0 1-.655-.705l.408-1.54A8.34 8.34 0 0 1 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
            </svg>
          </a>
        </div>
      </div>

      <div class="md:col-span-3 text-center md:text-left">
        <h4 class="text-sm font-semibold uppercase tracking-wider text-blue-400">Navegação</h4>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href="/" class="text-blue-200/70 hover:text-white hover:underline transition">Início</a></li>
          <li><a href="#sobre" class="text-blue-200/70 hover:text-white hover:underline transition">Minha História</a></li>
          <li><a href="#catalogo" class="text-blue-200/70 hover:text-white hover:underline transition">Catálogo</a></li>
          <li><a href="https://wa.me/seunumerodelefone" class="text-blue-200/70 hover:text-white hover:underline transition">Fazer Encomenda</a></li>
        </ul>
      </div>

      <div class="md:col-span-5 text-center md:text-left">
        <h4 class="text-sm font-semibold uppercase tracking-wider text-blue-400">Atendimento & Encomendas</h4>
        
        <div class="mt-4 space-y-3 text-sm text-blue-200/70">
          <p class="flex items-center justify-center md:justify-start gap-2">
            <span><Clock width={24} height={24}/></span> Seg a Sex: 09h às 18h | Sáb: 09h às 13h
          </p>
          <p class="flex items-center justify-center md:justify-start gap-2">
            <span><Pin width={24} height={24}/></span> Envio para todo o Brasil via Correios/Transportadora
          </p>
          
          <!-- <div class="mt-4 inline-flex items-center gap-2 p-3 rounded-2xl bg-blue-900/30 border border-blue-900 max-w-xs text-left">
            <span class="text-xl">🌿</span>
            <div class="text-xs">
              <p class="font-semibold text-blue-300">Consumo Consciente</p>
              <p class="text-[11px] text-blue-200/50">Embalagens recicláveis e fios de algodão sustentável.</p>
            </div>
          </div> -->
        </div>
      </div>
    </div>

  </div>
</footer>